# ============================================================
# 环境变量配置 — 复制此文件为 .env.local 并填写真实值
# ⚠️ .env.local 绝对不能提交到 Git（已在 .gitignore 中）
# ============================================================

# --- 数据库 ---
# 本地 PostgreSQL 格式：postgresql://用户名:密码@localhost:5432/数据库名
# 云端 Neon/Supabase 直接粘贴连接字符串
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/todo_app"

# --- NextAuth ---
# 生产环境改为真实域名，开发用 localhost 即可
NEXTAUTH_URL="http://localhost:3000"

# 随机密钥，用于加密 session token
# 生成方式：openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"

# --- 可选：邮件提醒（截止日期通知，可先跳过）---
# EMAIL_SERVER_HOST="smtp.gmail.com"
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER="your@gmail.com"
# EMAIL_SERVER_PASSWORD="app-specific-password"
# EMAIL_FROM="noreply@yourdomain.com"
